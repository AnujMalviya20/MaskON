# This is a template for environment variables needed for the project.

# Flask configuration
FLASK_ENV=development
FLASK_APP=app.py

# Secret key for session management
SECRET_KEY=your_secret_key_here

# Model path
MODEL_PATH=path_to_your_model.h5

# Upload folder path
UPLOAD_FOLDER=uploads/

# Alert sound file path
ALERT_SOUND=assets/sounds/alert.mp3

# Other configurations can be added as needed.